{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Karaoke Webview",
  "version": "0.1.0",
  "identifier": "app.karaokewebview.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Karaoke Webview",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
